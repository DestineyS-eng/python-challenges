def is_isogram(string):
#makes it all lower case so i can just look for similar letters
    lower=string.lower()
    letters=list(lower)
    for i in range (len(letters)):
#if the count of the letter the loop is on is greater than 1 its not an isogram 
        if letters.count(letters[i])>1:
            return False
#as it checks for false inside the loop anything outside has to be true      
    return True
        
            
